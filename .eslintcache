omponent } from \"react\";\nimport './App.css';\nimport { BrowserRouter as Router, Route, Switch, Redirect, HashRouter } from \"react-router-dom\"\n\n//Pages\n\nimport HomePage from \"./Pages/Homepage\"\nimport NotFound from \"./Pages/NotFound\"\nimport About from \"./Pages/About\"\nimport Blog from \"./Pages/blog\"\nimport Tester from \"./Pages/Contact/tester\"\n\nclass App extends Component{\n  render (){\n    return (\n      <HashRouter>\n        <Switch>\n          <Route exact path = \"/\" component = { HomePage }/>\n          <Route exact path = \"/About\" component = { About }/>\n          <Route exact path = \"/Blog\" component = { Blog } />\n          <Route exact path = \"/Contact\" component = { Tester } />\n          <Route path = \"/404\" component = { NotFound }/>\n          <Redirect to = \"/404\"/>\n        </Switch>\n      </HashRouter>\n    )\n  }\n}\n\nexport default App;\n","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/NotFound.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/Homepage.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/logo/logo.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/sidebar/sidebar.js",["82","83","84"],"import React, {useState} from \"react\";\nimport \"./sidebar.css\"\nimport {BrowserRouter as Router, Link} from \"react-router-dom\";\n//()=>setClipBoardStatus(\"Email : nissimram1812@gmail.com\")\n\n\nconst Sidebar = ( props ) => {\n  let status = false;\n\n  const [sidebarStatus, setSidebarStatus] = useState(false);\n\n  const clickHandlerBar = () => {\n    setSidebarStatus(!sidebarStatus)\n    //if sidebar closed so should tooltip\n  }\n\n\n  const [active, setActive] = useState(false);\n\n  const showTip = () => {\n      setActive(!active);\n    }\n\n  const childFunction = (e) => {\n    props.functionCallFromParent(e)\n  }\n\n\n  //{navigator.clipboard.writeText(  \"nissimram1812@gmail.com\")}\n\n\n\n  return (\n    <div className = \"container\">\n      <div className = \"sidebar_btn\">\n        <button className = {`classes ${sidebarStatus ? \"change\" : null}`}\n        onClick = {()=>{clickHandlerBar(); childFunction(!sidebarStatus)}}>\n          <div className = \"bar1\"></div>\n          <div className = \"bar2\"></div>\n          <div className = \"bar3\"></div>\n        </button>\n      </div>\n      <div className = {`classes ${sidebarStatus ? \"sidebar\" : \"off\"}`}>\n        <nav>\n          <ul>\n            <li>\n              <Link to = \"/\" className = \"link\"> Portfolio </Link>\n            </li>\n\n            <li>\n              <Link to = \"/About\" className = \"link\"> About </Link>\n            </li>\n\n            <li>\n              <Link to = \"/Blog\" className = \"link\"> Blog. </Link>\n            </li>\n\n            <li>\n              <a target = \"blank\" href = \"https://github.com/nizoom\"\n              className = \"link\">\n              GitHub </a>\n            </li>\n\n            <li>\n              <Link to = \"/Contact\" className = \"link\"> Contact </Link>\n            </li>\n\n\n          </ul>\n        </nav>\n      </div>\n    </div>\n  )\n}\n\nexport default Sidebar;\n","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/sidebar/testing.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/About.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/languages/languages.js",["85"],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/blog.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/tooltip/tooltip.js",[],["86","87"],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/blog_posts/post_one.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/backToTop/backToTop.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/Contact/tester.js",["88","89"],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/Contact/useForm.js",["90"],"import {useState, useEffect} from \"react\";\n\nconst useForm = (validate, submitForm) => {\n  const [ values, setValues ] = useState({\n    name: \"\",\n    reply_to : \"\",\n    message : \"\"\n  })\n\n  const [errors, setErrors] = useState({})\n\n  const [isSubmitting, setIsSubmitting] = useState()\n\n  const handleChange = (e) => {\n    const { name, value } = e.target;\n    setValues({\n      ...values,\n      [name] : value\n    })\n  }\n\n  const handleSubmit = (e) => {\n    console.log(\"handleSubmit\");\n    e.preventDefault();\n    setErrors(validate(values))\n    setIsSubmitting(true)\n    }\n\n  useEffect(() => {\n\n    if(Object.keys(errors).length === 0 && isSubmitting){\n      console.log(\"useEffectFired\");\n      submitForm()\n    }\n  }, [isSubmitting])\n\n\n\n\n  return { handleChange , values, handleSubmit, errors }\n}\n\n\nexport default useForm;\n","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/Contact/validateinfo.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/Contact/submit.js",[],{"ruleId":"91","replacedBy":"92"},{"ruleId":"93","replacedBy":"94"},{"ruleId":"95","severity":1,"message":"96","line":3,"column":27,"nodeType":"97","messageId":"98","endLine":3,"endColumn":33},{"ruleId":"95","severity":1,"message":"96","line":3,"column":26,"nodeType":"97","messageId":"98","endLine":3,"endColumn":32},{"ruleId":"95","severity":1,"message":"99","line":8,"column":7,"nodeType":"97","messageId":"98","endLine":8,"endColumn":13},{"ruleId":"95","severity":1,"message":"100","line":20,"column":9,"nodeType":"97","messageId":"98","endLine":20,"endColumn":16},{"ruleI