fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"30"},"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/index.js",[],["58","59"],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/reportWebVitals.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/App.js",["60"],"import React, { Component } from \"react\";\nimport './App.css';\nimport { BrowserRouter as Router, Route, Switch, Redirect, HashRouter } from \"react-router-dom\"\n\n//Pages\n\nimport HomePage from \"./Pages/Homepage\"\nimport NotFound from \"./Pages/NotFound\"\nimport About from \"./Pages/About\"\nimport Blog from \"./Pages/blog\"\n\nclass App extends Component{\n  render (){\n    return (\n      <HashRouter>\n        <Switch>\n          <Route exact path = \"/\" component = { HomePage }/>\n          <Route exact path = \"/About\" component = { About }/>\n          <Route exact path = \"/Blog\" component = { Blog } />\n          <Route path = \"/404\" component = { NotFound }/>\n          <Redirect to = \"/404\"/>\n        </Switch>\n      </HashRouter>\n    )\n  }\n}\n\nexport default App;\n","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/NotFound.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/Homepage.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/logo/logo.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/sidebar/sidebar.js",["61","62"],"import React, {useState} from \"react\";\nimport \"./sidebar.css\"\nimport {BrowserRouter as Router, Link} from \"react-router-dom\";\n//()=>setClipBoardStatus(\"Email : nissimram1812@gmail.com\")\nimport \"tippy.js/dist/tippy.css\";\nimport \"tippy.js/animations/perspective.css\"\n\nimport Tooltip from \"../tooltip/tooltip\"\n\n\n\nconst Sidebar = ( props ) => {\n  let status = false;\n\n  const [sidebarStatus, setSidebarStatus] = useState(false);\n\n  const clickHandlerBar = () => {\n    setSidebarStatus(!sidebarStatus)\n    //if sidebar closed so should tooltip\n  }\n\n\n  const [active, setActive] = useState(false);\n\n  const showTip = () => {\n      setActive(!active);\n    }\n\n  const childFunction = (e) => {\n    props.functionCallFromParent(e)\n  }\n\n\n  //{navigator.clipboard.writeText(  \"nissimram1812@gmail.com\")}\n\n\n\n  return (\n    <div className = \"container\">\n      <div>\n        <button className = {`classes ${sidebarStatus ? \"change\" : null}`}\n        onClick = {()=>{clickHandlerBar(); childFunction(!sidebarStatus)}}>\n          <div className = \"bar1\"></div>\n          <div className = \"bar2\"></div>\n          <div className = \"bar3\"></div>\n        </button>\n      </div>\n      <div className = {`classes ${sidebarStatus ? \"sidebar\" : \"off\"}`}>\n        <nav>\n          <ul>\n            <li>\n              <Link to = \"/\" className = \"link\"> Portfolio </Link>\n            </li>\n\n            <li>\n              <Link to = \"/About\" className = \"link\"> About </Link>\n            </li>\n\n            <li>\n              <Link to = \"/Blog\" className = \"link\"> Blog. </Link>\n            </li>\n\n            <li>\n              <a target = \"blank\" href = \"https://github.com/nizoom\"\n              className = \"link\">\n              GitHub </a>\n            </li>\n\n              <li onClick = {showTip}>\n                Contact\n              </li>\n              <Tooltip status = {active} />\n          </ul>\n        </nav>\n      </div>\n    </div>\n  )\n}\n\nexport default Sidebar;\n","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/sidebar/testing.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/About.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/languages/languages.js",["63"],"import React from \"react\"\nimport \"./languages.css\"\nimport Tippy from \"@tippyjs/react\";\nimport \"tippy.js/dist/tippy.css\";\n\n//images\nimport htmlImg from \"./lang_imgs/html_img.png\"\nimport cssImg from \"./lang_imgs/css_img.png\"\nimport jsImg from \"./lang_imgs/js_img.png\"\nimport nodeImg from \"./lang_imgs/node_img.png\"\nimport reactImg from \"./lang_imgs/react_img.png\"\n\n\n/*\n1. try a classname for all where custom attribute for each will be pluged in\n2. follow along with video\nddd*/\n\n\nconst Languages = ( props ) => {\n  return (\n\n  <div className = {props.classStatusForMobile != \"gif\"  && window.innerWidth < 850 ? \"navOpen\" : null}>\n    <div className = \"title_div\">\n      <h1 className = \"title\"> Languages </h1>\n    </div>\n    <div className = \"main\">\n      <div>\n      <Tippy content = {<span> HTML</span>}>\n        <img src = {htmlImg} width = \"\" height = \"150px\" alt = \"HTML\"\n        className = \"htmlImg\"/>\n      </Tippy>\n      </div>\n\n      <div>\n      <Tippy content = {<span> CSS </span>}>\n        <img src = {cssImg} width = \"\" height = \"150\" alt = \"CSS\"\n        className = \"cssImg\"/>\n      </Tippy>\n      </div>\n\n      <div>\n      <Tippy content = {<span> JavaScript </span>}>\n        <img src = {jsImg} width = \"\" height = \"150\" alt = \"JavaScript\"\n        className = \"jsImg\"/>\n      </Tippy>\n      </div>\n\n      <div>\n      <Tippy content = {<span> ReactJS </span>}>\n        <img src = {reactImg} width = \"\" height = \"120\" alt = \"ReactJS\"\n        className = \"reactImg\" />\n      </Tippy>\n      </div>\n\n      <div>\n      <Tippy content = {<span> NodeJS </span>}>\n        <img src = {nodeImg} width = \"\" height = \"120\" alt = \"NodeJS\"\n        className = \"nodeImg\"/>\n      </Tippy>\n      </div>\n\n\n    </div>\n  </div>\n  )\n}\n\nexport default Languages;\n","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/blog.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/tooltip/tooltip.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/blog_posts/post_one.js",[],{"ruleId":"64","replacedBy":"65"},{"ruleId":"66","replacedBy":"67"},{"ruleId":"68","severity":1,"message":"69","line":3,"column":27,"nodeType":"70","messageId":"71","endLine":3,"endColumn":33},{"ruleId":"68","severity":1,"message":"69","line":3,"column":26,"nodeType":"70","messageId":"71","endLine":3,"endColumn":32},{"ruleId":"68","severity":1,"message":"72","line":13,"column":7,"nodeType":"70","messageId":"71","endLine":13,"endColumn":13},{"ruleId":"73","severity":1,"message":"74","line":23,"column":48,"nodeType":"75","messageId":"76","endLine":23,"endColumn":50},"no-native-reassign",["77"],"no-negated-in-lhs",["78"],"no-unused-vars","'Router' is defined but never used.","Identifier","unusedVar","'status' is assigned a value but never used.","eqeqeq","Expected '!==' and instead saw '!='.","BinaryExpression","unexpected","no-global-assign","no-unsafe-negation"]