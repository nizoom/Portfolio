[{"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/index.js":"1","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/reportWebVitals.js":"2","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/App.js":"3","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/NotFound.js":"4","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/Homepage.js":"5","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/logo/logo.js":"6","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/sidebar/sidebar.js":"7","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/sidebar/testing.js":"8","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/About.js":"9","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/languages/languages.js":"10"},{"size":500,"mtime":1610335164651,"results":"11","hashOfConfig":"12"},{"size":362,"mtime":1610335164653,"results":"13","hashOfConfig":"12"},{"size":647,"mtime":1610400189904,"results":"14","hashOfConfig":"12"},{"size":162,"mtime":1610393949771,"results":"15","hashOfConfig":"12"},{"size":1211,"mtime":1610994078299,"results":"16","hashOfConfig":"12"},{"size":331,"mtime":1610477171732,"results":"17","hashOfConfig":"12"},{"size":1036,"mtime":1610650128452,"results":"18","hashOfConfig":"12"},{"size":485,"mtime":1610474571700,"results":"19","hashOfConfig":"12"},{"size":1592,"mtime":1610918877430,"results":"20","hashOfConfig":"12"},{"size":1333,"mtime":1611009581032,"results":"21","hashOfConfig":"12"},{"filePath":"22","messages":"23","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"24"},"j0s9j2",{"filePath":"25","messages":"26","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"24"},{"filePath":"27","messages":"28","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"29","usedDeprecatedRules":"24"},{"filePath":"30","messages":"31","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"24"},{"filePath":"32","messages":"33","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"34","usedDeprecatedRules":"24"},{"filePath":"35","messages":"36","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"24"},{"filePath":"37","messages":"38","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"39","usedDeprecatedRules":"24"},{"filePath":"40","messages":"41","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"42","messages":"43","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"44","usedDeprecatedRules":"24"},{"filePath":"45","messages":"46","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/index.js",[],["47","48"],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/reportWebVitals.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/App.js",["49"],"import React, { Component } from \"react\";\nimport './App.css';\nimport { BrowserRouter as Router, Route, Switch, Link, Redirect } from \"react-router-dom\"\n\n//Pages\n\nimport HomePage from \"./Pages/Homepage\"\nimport NotFound from \"./Pages/NotFound\"\nimport About from \"./Pages/About\"\n\nclass App extends Component{\n  render (){\n    return (\n      <Router>\n        <Switch>\n          <Route exact path = \"/\" component = { HomePage }/>\n          <Route path = \"/404\" component = { NotFound }/>\n          <Route exact path = \"/About\" component = { About }/>\n          <Redirect to = \"/404\"/>\n        </Switch>\n      </Router>\n    )\n  }\n}\n\nexport default App;\n","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/NotFound.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/Homepage.js",["50"],"import React, { Component } from \"react\";\nimport { Link } from \"react-router-dom\";\nimport Logo from \"../Components/logo/logo\"\nimport Sidebar from \"../Components/sidebar/sidebar\"\nimport Languages from \"../Components/languages/languages\"\nimport workingGif from \"../Components/project_layout/whale.gif\"\nimport classes from \"./css/homepage.css\"\n\nclass HomePage extends Component {\n  constructor (props) {\n    super(props)\n\n    this.state = {\n      sidebarVisible : false,\n      clickHandler : ( ) => {\n      this.setState(prevstate => ({\n        sidebarVisible : !prevstate.sidebarVisible }))\n      console.log(this.state.sidebarVisible);\n      }\n    }\n  }\n\n\n  render() {\n    return(\n      <div>\n          <Logo/>\n          <Sidebar/>\n\n          <div className = \"projects\">\n            <div className = \"comingSoonBanner\">\n              <h1> Welcome! Projects coming soon ...</h1>\n              <img src = {workingGif}\n                alt = \"Gif file\" className = \"gif\" height = \"600px\"/>\n                  <br/>\n                  <br/>\n                  <br/>\n\n            </div>\n          </div>\n\n          <Link to = \"/About\"> About </Link>\n          <Languages/>\n     </div>\n    )\n}}\n\nexport default HomePage;\n","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/logo/logo.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/sidebar/sidebar.js",["51"],"import React, {useState} from \"react\";\nimport classes from \"./sidebar.css\"\n\nconst Sidebar = ( props ) => {\n\n//make useState part of sidebar rather than receive props from homepage\n    // 1. the two features to replace is sidebarStatus and onClick\n    // 2.\n  const [sidebarStatus, setSidebarStatus] = useState(false);\n\n  const clickHandler = () => {\n    setSidebarStatus(!sidebarStatus)\n    console.log(sidebarStatus);\n  }\n\n\n  return (\n    <div >\n        <button className = {`classes ${sidebarStatus ? \"change\" : null}`}\n        onClick = {clickHandler}>\n          <div className = \"bar1\"></div>\n          <div className = \"bar2\"></div>\n          <div className = \"bar3\"></div>\n        </button>\n      <div className = {`classes ${sidebarStatus ? \"sidebar\" : \"off\"}`}>\n        <nav>\n          <ul>\n            <li> Portfolio </li>\n            <li> About </li>\n            <li> Blog </li>\n            <li> Contact </li>\n            <li> GitHub </li>\n          </ul>\n        </nav>\n      </div>\n    </div>\n  )\n}\n\nexport default Sidebar;\n","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/sidebar/testing.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/About.js",["52"],"import React from \"react\";\nimport Logo from \"../Components/logo/logo\"\nimport Sidebar from \"../Components/sidebar/sidebar\"\nimport classes from \"./css/about.css\"\nimport Languages from \"../Components/languages/languages\"\n\n\nconst About = ( props ) => {\n\n\n\n  return (\n    <div>\n      <Logo/>\n      <Sidebar />\n      <h1 className = \"title\"> Bįo</h1>\n      <div className = \"main\">\n\n\n          <h2 className = \"par_one\">\n           Nissim Ram is a New York based self-taught web developer. He\n           looks to build tools that tackle social issues and break down barriers\n           to information in ways that improve the lives of those in need. Before\n           entering the tech world Nissim received a bachelor’s degree in history\n           and anthropology from Brandeis University. Through this background he\n           brings to bear the tools to articulate complicated issues that face our\n           modern world and sees the potential for technology to be a solution.\n           Nissim uses front-end language fundamentals such as JavaScript, HTML,\n           and CSS to create new ways to visualize old paradigms such as the news and\n           ____ . </h2>\n\n\n           <br/>\n           <h2 className = \"par_two\">\n           Nissim has also assisted with producing websites for local New York\n           creatives such as the writer _____ and curator _____ .\n           He is passionate about improving his coding skills and is currently\n           seeking new opportunities to do so.\n           </h2>\n\n       </div>\n\n       <Languages/>\n   </div>\n\n  )\n}\n\nexport default About;\n","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/languages/languages.js",[],{"ruleId":"53","replacedBy":"54"},{"ruleId":"55","replacedBy":"56"},{"ruleId":"57","severity":1,"message":"58","line":3,"column":50,"nodeType":"59","messageId":"60","endLine":3,"endColumn":54},{"ruleId":"57","severity":1,"message":"61","line":7,"column":8,"nodeType":"59","messageId":"60","endLine":7,"endColumn":15},{"ruleId":"57","severity":1,"message":"61","line":2,"column":8,"nodeType":"59","messageId":"60","endLine":2,"endColumn":15},{"ruleId":"57","severity":1,"message":"61","line":4,"column":8,"nodeType":"59","messageId":"60","endLine":4,"endColumn":15},"no-native-reassign",["62"],"no-negated-in-lhs",["63"],"no-unused-vars","'Link' is defined but never used.","Identifier","unusedVar","'classes' is defined but never used.","no-global-assign","no-unsafe-negation"]