rCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/index.js",[],["59","60"],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/reportWebVitals.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/App.js",["61"],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/NotFound.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/Homepage.js",["62"],"import React, { Component } from \"react\";\nimport { Link } from \"react-router-dom\";\nimport Logo from \"../Components/logo/logo\"\nimport Sidebar from \"../Components/sidebar/sidebar\"\nimport Languages from \"../Components/languages/languages\"\nimport workingGif from \"../Components/project_layout/whale.gif\"\nimport classes from \"./css/homepage.css\"\n\nclass HomePage extends Component {\n  constructor (props) {\n    super(props)\n\n    this.state = {\n      sidebarVisible : false,\n      clickHandler : ( ) => {\n      this.setState(prevstate => ({\n        sidebarVisible : !prevstate.sidebarVisible }))\n      console.log(this.state.sidebarVisible);\n      }\n    }\n  }\n\n\n  render() {\n    return(\n      <div>\n          <Logo/>\n          <Sidebar/>\n\n          <div className = \"projects\">\n            <div className = \"comingSoonBanner\">\n              <h1> Welcome! Projects coming soon ...</h1>\n              <br/>\n              <img src = {workingGif}\n                alt = \"Gif file\" className = \"gif\" height = \"600px\"/>\n\n                  <br/>\n\n            </div>\n          </div>\n\n          <Link to = \"/Blog\"> Blog </Link>\n          <Languages/>\n     </div>\n    )\n}}\n\nexport default HomePage;\n","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/logo/logo.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/sidebar/sidebar.js",["63","64","65"],"import React, {useState, forwardRef} from \"react\";\nimport \"./sidebar.css\"\nimport {BrowserRouter as Router, Link} from \"react-router-dom\";\n//()=>setClipBoardStatus(\"Email : nissimram1812@gmail.com\")\nimport Tippy from \"@tippyjs/react\";\nimport \"tippy.js/dist/tippy.css\";\nimport \"tippy.js/animations/perspective.css\"\n\nimport Tooltip from \"../tooltip/tooltip\"\n\n\n\nconst Sidebar = ( props ) => {\n\n  const [sidebarStatus, setSidebarStatus] = useState(false);\n\n  const clickHandlerBar = () => {\n    setSidebarStatus(!sidebarStatus)\n    //if sidebar closed so should tooltip\n  }\n\n  const [active, setActive] = useState(false);\n\n  const showTip = () => {\n\n      setActive(!active);\n      console.log(\"test\");\n\n    }\n\n\n\n  //{navigator.clipboard.writeText(  \"nissimram1812@gmail.com\")}\n\n\n\n  return (\n    <div >\n        <button className = {`classes ${sidebarStatus ? \"change\" : null}`}\n        onClick = {clickHandlerBar}>\n          <div className = \"bar1\"></div>\n          <div className = \"bar2\"></div>\n          <div className = \"bar3\"></div>\n        </button>\n      <div className = {`classes ${sidebarStatus ? \"sidebar\" : \"off\"}`}>\n        <nav>\n          <ul>\n            <li>\n              <Link to = \"/\" className = \"link\"> Portfolio </Link>\n            </li>\n\n            <li>\n              <Link to = \"/About\" className = \"link\"> About </Link>\n            </li>\n\n            <li>\n              <Link to = \"/Blog\" className = \"link\"> Blog. </Link>\n            </li>\n\n            <li>\n              <a target = \"blank\" href = \"https://github.com/nizoom\"\n              className = \"link\">\n              GitHub </a>\n            </li>\n\n              <li onClick = {showTip}>\n                Contact\n              </li>\n              <Tooltip status = {active} />\n\n\n\n\n\n          </ul>\n        </nav>\n      </div>\n    </div>\n  )\n}\n\nexport default Sidebar;\n","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/sidebar/testing.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/About.js",["66"],"import React from \"react\";\nimport Logo from \"../Components/logo/logo\"\nimport Sidebar from \"../Components/sidebar/sidebar\"\nimport classes from \"./css/about.css\"\nimport Languages from \"../Components/languages/languages\"\n\n\nconst About = ( props ) => {\n\n\n\n  return (\n    <div>\n      <Logo/>\n      <Sidebar/>\n\n      <h1 className = \"title\"> Bįo</h1>\n      <div className = \"main\">\n\n\n          <h2 className = \"par_one\">\n           Nissim Ram is a New York based self-taught web developer. He\n           looks to build tools that tackle social issues and break down barriers\n           to information in ways that improve the lives of those in need. Before\n           entering the tech world Nissim received a bachelor’s degree in history\n           and anthropology from Brandeis University. Through this background he\n           brings to bear the tools to articulate complicated issues that face our\n           modern world and sees the potential for technology to be a solution.\n           Nissim uses front-end language fundamentals such as JavaScript, HTML,\n           and CSS to create new ways to visualize old paradigms such as the news and\n           ____ . </h2>\n\n\n           <br/>\n           <h2 className = \"par_two\">\n           Nissim has also assisted with producing websites for local New York\n           creatives such as the writer _____ and curator _____ .\n           He is passionate about improving his coding skills and is currently\n           seeking new opportunities to do so.\n           </h2>\n\n       </div>\n\n       <Languages/>\n   </div>\n\n  )\n}\n\nexport default About;\n","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/languages/languages.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Pages/blog.js",[],"/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/tooltip/tooltip.js",["67"],"import React, { useState } from \"react\";\nimport \"./tooltip.css\";\n\nconst Tooltip = (props) => {\n\n  // take this logic and put it in the sidebar component so that the onlick\n  // is connected to the li rather than the tool\n\n//onClick={showTip}\n\n  return (\n    <div className = {props.status? \"contact_wrapper\" : \"invisible\"}>\n      <h4>\n        <u>Email </u>: <br/><br/> nissimram1812@gmail.com </h4>\n      <br/>\n      <br/>\n      <h4> <u> LinkedIn </u>:<br/><br/> https://www.linkedin.com/in/nissimram/ </h4>\n\n    </div>\n  );\n};\n\nexport default Tooltip;\n","/Users/nissimram/Desktop/Programming/nissimram.com/Portfolio Code/my-site/src/Components/blog_posts/post_one.js",[],{"ruleId":"68","replacedBy":"69"},{"ruleId":"70","replacedBy":"71"},{"ruleId":"72","severity":1,"message":"73","line":3,"column":60,"nodeType":"74","messageId":"75","endLine":3,"endColumn":70},{"ruleId":"72","severity":1,"message":"76","line":7,"column":8,"nodeType":"74","messageId":"75","endLine":7,"endColumn":15},{"ruleId":"72","severity":1,"message":"77","line":1,"column":26,"nodeType":"74","messageId":"75","endLine":1,"endColumn":36},{"ruleId":"72","severity":1,"message":"78","line":3,"column":26,"nodeType":"74","messageId":"75","endLine":3,"endColumn":32},{"ruleId":"72","severity":1,"message":"79","line":5,"column":8,"nodeType":"74","messageId":"75","endLine":5,"endColumn":13},{"ruleId":"72","severity":1,"message":"76","line":4,"column":8,"nodeType":"74","messageId":"75","endLine":4,"endColumn":15},{"ruleId":"72","severity":1,"message":"80","line":1,"column":17,"nodeType":"74","messageId":"75","endLine":1,"endColumn":25},"no-native-reassign",["81"],"no-negated-in-lhs",["82"],"no-unused-vars","'HashRouter' is defined but never used.","Identifier","unusedVar","'classes' is defined but never used.","'forwardRef' is defined but never used.","'Router' is defined but never used.","'Tippy' is defined but never used.","'useState' is defined but never used.","no-global-assign","no-unsafe-negation"]